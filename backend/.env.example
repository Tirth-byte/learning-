# ---------------------------------------------------------------------------
# Server environment. Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must never be committed.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER@localhost:5432/rental_db?schema=public"

# Port the API listens on.
PORT=5001

# Secret used to sign JWT session tokens. Use a long random string in production.
JWT_SECRET="replace-with-a-long-random-secret"

# "development" or "production". In production a real JWT_SECRET is required.
NODE_ENV="development"

# SMTP email service credentials (e.g., Resend or SendGrid SMTP)
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="re_your_api_key"
EMAIL_FROM="onboarding@resend.dev"

# Twilio SMS credentials
TWILIO_ACCOUNT_SID="ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"
